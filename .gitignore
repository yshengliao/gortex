# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.html

# Dependency directories
vendor/

# Go workspace file
go.work

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Environment files
.env
.env.local

# Build artifacts
/bin/
/dist/

# Go build outputs at project root (go build ./examples/...)
/auth
/basic
/websocket
/perfcheck
/contextcheck

# Example binaries in their directories
examples/*/[a-z]*
!examples/*/*.go
!examples/*/*.md
!examples/*/*.yaml
!examples/*/*.yml

# Benchmark artefacts
.benchmark/

# Temporary files
*.tmp
*.log